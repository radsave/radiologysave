# ClearScan Frontend — Environment Variables
# Copy to .env: cp .env.example .env

# API base URL — when using Vite dev proxy (default), leave as /api
# When running frontend standalone against a remote API, set full URL:
#   VITE_API_URL=https://api.yourclearscan.com/api
VITE_API_URL=/api

# Your Stripe publishable key (pk_test_... for development)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# Google Maps key for address autocomplete in the admin center form.
# MUST be a SEPARATE, restricted key from the backend one (it's exposed in the browser).
# Enable: Places API + Maps JavaScript API. Restrict by HTTP referrer (your domain + localhost).
# Leave as placeholder to disable autocomplete (admins fill address fields manually).
VITE_GOOGLE_MAPS_API_KEY=YOUR_BROWSER_GOOGLE_MAPS_KEY_HERE
