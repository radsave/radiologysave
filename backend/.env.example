# ─────────────────────────────────────────────────────────────────────────────
# ClearScan Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# For local WSL install (after running scripts/db-setup.sh):
DATABASE_URL=postgresql://clearscan:clearscan_dev_password@localhost:5432/clearscan_db

# For Docker Compose (DATABASE_URL is overridden in docker-compose.yml,
# so you can leave this as-is for Docker usage):
# DATABASE_URL=postgresql://clearscan:clearscan_dev_password@postgres:5432/clearscan_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=replace-this-with-a-long-random-string-use-openssl-rand-hex-64
JWT_EXPIRES_IN=7d

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_...) during development
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# Get after running: stripe listen --forward-to localhost:4000/api/payments/webhook
# See: bash scripts/stripe-webhook.sh
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Used for ZIP code geocoding. Without this key a hardcoded TX fallback is used.
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Geocoding API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ── Anthropic Claude API (AI features) ────────────────────────────────────────
# Powers the Plain-English Scan Finder and Referral Auto-Extraction.
# Get a key at: https://console.anthropic.com → API Keys
# Without this key, AI endpoints return 503 and the UI falls back to dropdowns.
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE
# Optional: override the model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Email (optional) ──────────────────────────────────────────────────────────
# For booking confirmation emails. Leave blank to skip email sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
# Use an App Password (not your regular Gmail password):
# https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@clearscan.com

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used for CORS and Stripe redirect URLs
FRONTEND_URL=http://localhost:5173
